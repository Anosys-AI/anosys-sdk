# Required: obtain from https://console.anosys.ai/collect/integrationoptions
ANOSYS_API_KEY=your_anosys_api_key_here

# Required when using anosys-sdk-openai or anosys-sdk-openai-agents
OPENAI_API_KEY=your_openai_api_key_here

