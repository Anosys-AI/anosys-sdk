{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": true,
  "include-component-in-tag": true,
  "include-v-in-tag": true,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": false,
  "packages": {
    "packages/python/core": {
      "release-type": "python",
      "package-name": "anosys-sdk-core",
      "component": "core"
    },
    "packages/python/openai": {
      "release-type": "python",
      "package-name": "anosys-sdk-openai",
      "component": "openai-py"
    },
    "packages/python/openai_agents": {
      "release-type": "python",
      "package-name": "anosys-sdk-openai-agents",
      "component": "openai-agents-py"
    },
    "packages/python/claude_code": {
      "release-type": "python",
      "package-name": "anosys-claude-code",
      "component": "claude-code"
    },
    "packages/js/openai": {
      "release-type": "node",
      "package-name": "anosys-sdk-openai",
      "component": "openai-js"
    },
    "packages/js/openai-agents": {
      "release-type": "node",
      "package-name": "anosys-sdk-openai-agents",
      "component": "openai-agents-js"
    }
  }
}
